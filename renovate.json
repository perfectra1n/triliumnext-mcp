{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["after 2am and before 6am"],
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "description": "Automerge non-breaking updates (CI must pass before merge)",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "bump", "lockFileMaintenance"],
      "automerge": true
    },
    {
      "description": "Never automerge majors (treated as breaking)",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Pre-1.0 minor bumps are breaking under semver; require manual review",
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": "<1.0.0",
      "automerge": false
    }
  ]
}
